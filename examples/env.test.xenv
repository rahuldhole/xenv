# Database Configuration Example

# @input label="Database Host"
DB_HOST=localhost

# @input label="Database Port"
DB_PORT=5432

# @input label="Database Name"
DB_NAME=myapp

# @input label="Database User"
DB_USER=admin

# @password label="Database Password"
DB_PASSWORD=

# @select label="Database Type" options=mysql,postgres,sqlite,mongodb
DB_TYPE=postgres

# @checkbox label="Enable SSL Connection"
DB_SSL=true

# @checkbox label="Enable Debug Mode"
DEBUG=false
