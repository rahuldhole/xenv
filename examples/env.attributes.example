# Attribute Examples

# @text label="Required Text" required
REQUIRED_TEXT=hello

# @number label="Readonly Number" readonly
READONLY_NUMBER=123

# @text label="Text with Note" note="This is a note"
TEXT_WITH_NOTE=foo

# @select label="Select Option" options=red,green,blue required
SELECT_COLOR=red

# @password label="Password" required readonly
PASSWORD=secret

# @file label="Config File" required
CONFIG_FILE=/etc/app/config.json

# @url label="Homepage" readonly
HOMEPAGE_URL=https://homepage.com
