# =========================================
# Modern App Environment Template
# For use with xenv CLI
# =========================================

# -----------------------------------------
# General Application Settings
# -----------------------------------------
# @input label="Application Name" note="Your app display name"
APP_NAME=MyAwesomeApp

# @select label="Environment" options=development,testing,staging,production note="Select current environment"
APP_ENV=development

# @input label="Application Version" note="Semantic versioning, e.g., 1.0.0"
APP_VERSION=1.0.0

# -----------------------------------------
# Server Configuration
# -----------------------------------------
# @input label="Server Host" note="IP or hostname the server will bind to"
SERVER_HOST=0.0.0.0

# @input label="Server Port" type=int note="Port must be a number between 1024-65535"
SERVER_PORT=8080

# @checkbox label="Enable HTTPS" note="Enable TLS for secure connections"
SERVER_HTTPS=false

# @input label="Certificate Path" type=file note="Required if HTTPS is enabled"
CERT_PATH=

# @input label="Key Path" type=file note="Required if HTTPS is enabled"
KEY_PATH=

# -----------------------------------------
# Database Configuration
# -----------------------------------------
# @input label="Database Host" note="Hostname or IP"
DB_HOST=localhost

# @input label="Database Port" type=int note="Port number"
DB_PORT=5432

# @input label="Database Name"
DB_NAME=myapp_db

# @input label="Database User"
DB_USER=myapp_user

# @password label="Database Password"
DB_PASSWORD=

# -----------------------------------------
# API Configuration
# -----------------------------------------
# @input label="API Version" note="Version prefix for API routes"
API_VERSION=v1

# @password label="API Secret Key" note="Used for internal API authentication"
API_SECRET=

# @select label="Log Level" options=debug,info,warn,error note="Default logging level"
LOG_LEVEL=info

# -----------------------------------------
# Feature Flags
# -----------------------------------------
# @checkbox label="Enable User Registration"
FEATURE_REGISTRATION=true

# @checkbox label="Enable Social Login"
FEATURE_SOCIAL_LOGIN=false

# @checkbox label="Enable Email Notifications"
FEATURE_EMAIL_NOTIFICATIONS=true

# @checkbox label="Enable Beta Features"
FEATURE_BETA=false

# -----------------------------------------
# External Services
# -----------------------------------------
# @input label="SMTP Host"
SMTP_HOST=smtp.mail.com

# @input label="SMTP Port" type=int
SMTP_PORT=587

# @checkbox label="SMTP Use TLS"
SMTP_TLS=true

# @input label="SMTP User"
SMTP_USER=user@mail.com

# @password label="SMTP Password"
SMTP_PASSWORD=

# @input label="Redis Host"
REDIS_HOST=localhost

# @input label="Redis Port" type=int
REDIS_PORT=6379

# -----------------------------------------
# Limits & Timeouts
# -----------------------------------------
# @input label="Max Connections" type=int note="Maximum simultaneous connections"
MAX_CONNECTIONS=100

# @input label="Request Timeout" type=float note="Timeout in seconds"
REQUEST_TIMEOUT=30.0

# @input label="Session Expiry" type=int note="Session expiry in minutes"
SESSION_EXPIRY=60

# -----------------------------------------
# Optional Lists / Arrays
# -----------------------------------------
# @list label="Allowed Origins" note="Comma separated list of allowed CORS origins"
ALLOWED_ORIGINS=http://localhost:3000,http://example.com

# @list label="Admin Emails" note="Comma separated list of super admin emails"
ADMIN_EMAILS=admin@example.com

# -----------------------------------------
# Skip Section Example
# -----------------------------------------
# @skip note="All variables below will remain unchanged if they already exist"
# These vars will not be prompted
LEGACY_SERVICE_URL=http://legacy.example.com
LEGACY_SERVICE_KEY=abc123
LEGACY_FEATURE_FLAG=false

# -----------------------------------------
# Custom Validations Instructions
# -----------------------------------------
# - Any field with type=int or type=float should only accept numeric input
# - Any @password field should not be empty in production
# - @list fields should be comma-separated
# - HTTPS fields (CERT_PATH/KEY_PATH) required if SERVER_HTTPS=true
# - ENV selection should match one of the provided options
# - Log levels must be one of debug/info/warn/error
# - Boolean fields only accept true/false or y/n
# - @skip marks all variables below as "do not prompt / leave as is"

