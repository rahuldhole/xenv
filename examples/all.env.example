# =========================================
# Modern App Environment Template
# For use with xenv CLI
# =========================================

# -----------------------------------------
# General Application Settings
# -----------------------------------------

# Your existing .env variables will take input as plain text.
PLAIN_TEXT_VAR=Hello

# @text label="Application Name" note="Your app display name" required
APP_NAME=MyAwesomeApp

# @select label="Environment" options=development,testing,staging,production note="Select current environment" required=true
APP_ENV=development

# @text label="Application Version" note="Semantic versioning" pattern="^\d+\.\d+\.\d+$" required
APP_VERSION=1.0.0

# -----------------------------------------
# Server Configuration
# -----------------------------------------
# @text label="Server Host" note="IP or hostname the server will bind to"
SERVER_HOST=0.0.0.0

# @number label="Server Port" note="Port must be a number between 1024-65535" required
SERVER_PORT=8080

# @boolean label="Enable HTTPS" note="Enable TLS for secure connections"
SERVER_HTTPS=false

# @file label="Certificate Path" note="Required if HTTPS is enabled" required
CERT_PATH=

# @file label="Key Path" note="Required if HTTPS is enabled"
KEY_PATH=

# @url label="Base URL" note="Full URL to your application" required
BASE_URL=http://localhost:8080

# -----------------------------------------
# Database Configuration
# -----------------------------------------
# @text label="Database Host" note="Hostname or IP"
DB_HOST=localhost

# @number label="Database Port" note="Port number"
DB_PORT=5432

# @text label="Database Name"
DB_NAME=myapp_db

# @text label="Database User"
DB_USER=myapp_user

# @password label="Database Password" required
DB_PASSWORD=

# @url label="Database URL" note="Full connection URL" required
DB_URL=postgresql://localhost:5432/myapp_db

# -----------------------------------------
# API Configuration
# -----------------------------------------
# @text label="API Version" note="Version prefix for API routes"
API_VERSION=v1

# @password label="API Secret Key" note="Used for internal API authentication"
API_SECRET=

# @select label="Log Level" options=debug,info,warn,error note="Default logging level"
LOG_LEVEL=info

# -----------------------------------------
# Feature Flags
# -----------------------------------------
# @boolean label="Enable User Registration"
FEATURE_REGISTRATION=true

# @boolean label="Enable Social Login"
FEATURE_SOCIAL_LOGIN=false

# @boolean label="Enable Email Notifications"
FEATURE_EMAIL_NOTIFICATIONS=true

# @boolean label="Enable Beta Features"
FEATURE_BETA=false

# -----------------------------------------
# External Services
# -----------------------------------------
# @text label="SMTP Host"
SMTP_HOST=smtp.mail.com

# @number label="SMTP Port"
SMTP_PORT=587

# @boolean label="SMTP Use TLS"
SMTP_TLS=true

# @text label="SMTP User"
SMTP_USER=user@mail.com

# @password label="SMTP Password"
SMTP_PASSWORD=

# @url label="Email Service API" note="External email service endpoint"
EMAIL_API_URL=https://api.emailservice.com/v1

# @text label="Redis Host"
REDIS_HOST=localhost

# @number label="Redis Port"
REDIS_PORT=6379

# -----------------------------------------
# Limits & Timeouts
# -----------------------------------------
# @number label="Max Connections" note="Maximum simultaneous connections"
MAX_CONNECTIONS=100

# @float label="Request Timeout" note="Timeout in seconds"
REQUEST_TIMEOUT=30.0

# @number label="Session Expiry" note="Session expiry in minutes"
SESSION_EXPIRY=60

# @date label="Service Start Date" note="When did this service go live? (YYYY-MM-DD)" required
SERVICE_START_DATE=2024-01-01

# @date label="License Expiry" note="License expiration (MM/DD/YYYY)" pattern="^\d{2}/\d{2}/\d{4}$" required=true
LICENSE_EXPIRY=12/31/2025

# -----------------------------------------
# Optional Lists / Arrays
# -----------------------------------------
# @list label="Allowed Origins" note="Comma separated list of allowed CORS origins"
ALLOWED_ORIGINS=http://localhost:3000,http://example.com

# @list label="Admin Emails" note="Comma separated list of super admin emails" required
ADMIN_EMAILS=admin@example.com,superadmin@example.com

# @list label="Trusted IPs" note="Comma separated list of trusted IP addresses"
TRUSTED_IPS=127.0.0.1,192.168.1.1

# -----------------------------------------
# Custom Pattern Examples
# -----------------------------------------
# @text label="Phone Number" note="US format (XXX-XXX-XXXX)" pattern="^\d{3}-\d{3}-\d{4}$"
PHONE=555-123-4567

# @text label="Zip Code" note="US 5-digit zip" pattern="^\d{5}$"
ZIP_CODE=12345

# @text label="API Key" note="32 character hex key" pattern="^[a-fA-F0-9]{32}$"
API_KEY=abcdef0123456789abcdef0123456789

# @hidden note="Do not prompt for this field"
HIDDEN_API_KEY=abcdef0123456789abcdef0123456789

# -----------------------------------------
# Skip Section Example
# -----------------------------------------
# @skip note="All variables below will remain unchanged if they already exist"
# These vars will not be prompted
LEGACY_SERVICE_URL=http://legacy.example.com
LEGACY_SERVICE_KEY=abc123
LEGACY_FEATURE_FLAG=false

# -----------------------------------------
# New DSL Examples
# -----------------------------------------
# @button label="Click Me"
BUTTON_ACTION=DoSomething

# @checkbox label="Accept Terms"
ACCEPT_TERMS=true

# @color label="Theme Color"
THEME_COLOR=#ff0000

# @datetime label="Deployment DateTime"
DEPLOYMENT_DATETIME=2024-05-01 14:00

# @email label="Support Email" required
SUPPORT_EMAIL=support@example.com

# @image label="Logo Path"
LOGO_PATH=/assets/logo.png

# @month label="Billing Month"
BILLING_MONTH=2024-05

# @radio label="Gender" options=male,female,other
GENDER=other

# @range label="Volume" default="50"
VOLUME=50

# @reset label="Reset Config" default="default"
RESET_CONFIG=default

# @tel label="Contact Phone"
CONTACT_PHONE=+1-555-123-4567

# @time label="Daily Backup Time"
BACKUP_TIME=02:00

# @week label="Sprint Week"
SPRINT_WEEK=2024-W18

# @readonly label="Read Only Field"
READ_ONLY_FIELD=readonly_value

