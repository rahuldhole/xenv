# Validation Examples

# @text label="Username" pattern="^[a-zA-Z0-9]{3,20}$" required
USERNAME=johndoe

# @email label="Email" required
EMAIL=user@example.com

# @number label="Age" required
AGE=25

# @float label="Price"
PRICE=19.99

# @date label="Birth Date" pattern="^\d{4}-\d{2}-\d{2}$" required
BIRTH_DATE=1990-01-15

# @date label="Appointment" pattern="^\d{2}/\d{2}/\d{4} \d{2}:\d{2}$"
APPOINTMENT=12/25/2024 14:30

# @tel label="Phone" pattern="^\+?[0-9\- ]+$"
PHONE=+1-555-123-4567

# @list label="Allowed Domains" required
ALLOWED_DOMAINS=example.com,test.com,demo.org

# @text label="Zip Code" pattern="^\d{5}$"
ZIP_CODE=12345

# @text label="API Key" pattern="^[a-fA-F0-9]{32}$"
API_KEY=abcdef0123456789abcdef0123456789
