# Input Types Example

# @text label="Text Field"
TEXT_FIELD=Some text

# @number label="Number Field"
NUMBER_FIELD=42

# @float label="Float Field"
FLOAT_FIELD=3.14

# @date label="Date Field"
DATE_FIELD=2024-05-01

# @datetime label="DateTime Field"
DATETIME_FIELD=2024-05-01 14:00

# @file label="File Path"
FILE_PATH=/tmp/file.txt

# @url label="Website URL"
WEBSITE_URL=https://example.com

# @password label="Password"
PASSWORD=

# @select label="Select Option" options=one,two,three
SELECT_OPTION=one

# @boolean label="Boolean Field"
BOOLEAN_FIELD=true

# @list label="List Field"
LIST_FIELD=foo,bar,baz

# @button label="Button Script"
BUTTON_SCRIPT=DoSomething

# @checkbox label="Accept Terms"
ACCEPT_TERMS=true

# @color label="Theme Color"
THEME_COLOR=#ff0000

# @email label="Support Email"
SUPPORT_EMAIL=support@example.com

# @image label="Logo Path"
LOGO_PATH=/assets/logo.png

# @month label="Billing Month"
BILLING_MONTH=2024-05

# @radio label="Gender" options=male,female,other
GENDER=other

# @range label="Volume" default="50"
VOLUME=50

# @reset label="Reset Config" default="default"
RESET_CONFIG=default

# @tel label="Contact Phone"
CONTACT_PHONE=+1-555-123-4567

# @time label="Daily Backup Time"
BACKUP_TIME=02:00

# @week label="Sprint Week"
SPRINT_WEEK=2024-W18

# @readonly label="Read Only Field"
READ_ONLY_FIELD=readonly_value

# @hidden note="Do not prompt for this field"
HIDDEN_API_KEY=abcdef0123456789abcdef0123456789

# @skip note="All variables below will remain unchanged if they already exist"
SKIPPED_VAR=should_not_prompt
